<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --navy-deep:#05070f;
  --navy:#0a0e1e;
  --navy-soft:#10152b;
  --gold:#d9b45c;
  --gold-bright:#f0d489;
  --violet:#8b6cf0;
  --violet-glow:rgba(139,108,240,.35);
  --cyan:#7fd8e8;
  --ink:#e9e6dd;
  --ink-dim:#a5a3b8;
  --hairline:rgba(217,180,92,.18);
  --ease:cubic-bezier(.22,.9,.3,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--navy-deep);
  color:var(--ink);
  font-family:'Inter',system-ui,sans-serif;
  font-weight:300;
  line-height:1.7;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
::selection{background:var(--violet);color:#fff}

/* ---------- ambient layers ---------- */
#stars{position:fixed;inset:0;z-index:0;pointer-events:none}
.veil{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(ellipse 80% 55% at 50% -10%, rgba(139,108,240,.14), transparent 60%),
    radial-gradient(ellipse 60% 40% at 85% 100%, rgba(127,216,232,.05), transparent 65%);
}
main{position:relative;z-index:1}

/* ---------- type ---------- */
h1,h2,h3,.serif{
  font-family:'Cormorant Garamond',serif;
  font-weight:500;
  line-height:1.12;
  letter-spacing:.01em;
}
.eyebrow{
  font-family:'Inter',sans-serif;
  font-size:.68rem;
  font-weight:500;
  letter-spacing:.42em;
  text-transform:uppercase;
  color:var(--gold);
}
.lede{color:var(--ink-dim);font-size:1.05rem;max-width:34em}
em{font-style:italic;color:var(--gold-bright)}

/* ---------- layout ---------- */
.wrap{max-width:1060px;margin:0 auto;padding:0 24px}
section{padding:110px 0}
.center{text-align:center}
.center .lede{margin-left:auto;margin-right:auto}

/* ---------- reveal on scroll ---------- */
.rv{opacity:0;transform:translateY(26px);transition:opacity 1s var(--ease),transform 1s var(--ease)}
.rv.in{opacity:1;transform:none}
.rv.d1{transition-delay:.12s}.rv.d2{transition-delay:.24s}.rv.d3{transition-delay:.36s}

/* ---------- buttons ---------- */
.btn{
  display:inline-flex;align-items:center;gap:.7em;
  font-family:'Inter',sans-serif;font-size:.82rem;font-weight:500;
  letter-spacing:.18em;text-transform:uppercase;
  color:var(--navy-deep);text-decoration:none;
  background:linear-gradient(135deg,var(--gold-bright),var(--gold) 55%,#b8933f);
  padding:1.15em 2.4em;border-radius:100px;
  position:relative;isolation:isolate;
  box-shadow:0 0 0 1px rgba(240,212,137,.4),0 8px 40px -8px rgba(217,180,92,.45);
  transition:transform .4s var(--ease),box-shadow .4s var(--ease);
}
.btn::after{
  content:"";position:absolute;inset:-14px;border-radius:inherit;z-index:-1;
  background:radial-gradient(closest-side,var(--violet-glow),transparent);
  opacity:0;transition:opacity .4s;
}
.btn:hover{transform:translateY(-2px);box-shadow:0 0 0 1px rgba(240,212,137,.6),0 14px 60px -8px rgba(217,180,92,.6)}
.btn:hover::after{opacity:1}
.btn:focus-visible{outline:2px solid var(--cyan);outline-offset:4px}
.btn-note{display:block;margin-top:1.1em;font-size:.75rem;letter-spacing:.12em;color:var(--ink-dim)}

.link-quiet{
  color:var(--cyan);text-decoration:none;font-size:.85rem;letter-spacing:.06em;
  border-bottom:1px solid rgba(127,216,232,.3);padding-bottom:2px;
  transition:border-color .3s;
}
.link-quiet:hover{border-color:var(--cyan)}
.link-quiet:focus-visible{outline:2px solid var(--cyan);outline-offset:3px}

/* ---------- hero ---------- */
.hero{
  min-height:100svh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;text-align:center;
  padding:120px 24px 90px;position:relative;
}
.portal{
  position:relative;width:min(78vw,560px);aspect-ratio:1;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:-8vmin;
}
.portal svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible}
.ring-slow{animation:spin 140s linear infinite;transform-origin:center}
.ring-mid{animation:spin 90s linear infinite reverse;transform-origin:center}
.ring-fast{animation:spin 60s linear infinite;transform-origin:center}
@keyframes spin{to{transform:rotate(360deg)}}
.portal-core{
  position:relative;z-index:2;width:34%;aspect-ratio:1;border-radius:50%;
  background:radial-gradient(circle at 50% 42%, rgba(139,108,240,.28), rgba(10,14,30,.0) 70%);
  display:flex;align-items:center;justify-content:center;
  animation:breathe 7s ease-in-out infinite;
}
@keyframes breathe{0%,100%{filter:brightness(1)}50%{filter:brightness(1.35)}}
.portal-core span{
  font-family:'Cormorant Garamond',serif;font-size:clamp(2.4rem,7vw,3.6rem);
  color:var(--gold-bright);letter-spacing:.22em;padding-left:.22em;
  text-shadow:0 0 30px rgba(217,180,92,.55),0 0 80px rgba(139,108,240,.4);
}
.hero h1{
  font-size:clamp(2.5rem,6.4vw,4.6rem);
  max-width:12.5em;margin:0 auto .45em;
  position:relative;z-index:2;
}
.hero .lede{position:relative;z-index:2;margin:0 auto 2.6em}
.scroll-hint{
  position:absolute;bottom:26px;left:50%;transform:translateX(-50%);
  width:1px;height:54px;background:linear-gradient(var(--gold),transparent);
  opacity:.6;
}

/* ---------- journey strip ---------- */
.journey{border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);background:rgba(10,14,30,.5)}
.journey .wrap{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
.stage{padding:34px 20px;text-align:center;position:relative}
.stage+.stage::before{
  content:"";position:absolute;left:0;top:28%;bottom:28%;width:1px;
  background:linear-gradient(transparent,var(--hairline),transparent);
}
.stage .serif{font-size:1.5rem;color:var(--gold-bright)}
.stage p{font-size:.78rem;color:var(--ink-dim);letter-spacing:.04em;margin-top:.3em}

/* ---------- what we do ---------- */
.about-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:70px;align-items:center}
.about-grid h2{font-size:clamp(2rem,4vw,3rem);margin:0.6em 0 0.55em}
.sigil{
  width:100%;max-width:340px;margin:0 auto;display:block;
}
.sigil circle,.sigil path,.sigil line{stroke:var(--gold);fill:none;stroke-width:.6;opacity:.75}
.sigil .v{stroke:var(--violet)}
.sigil .c{stroke:var(--cyan);opacity:.5}

/* ---------- calculator feature ---------- */
.calc{
  border:1px solid var(--hairline);border-radius:24px;
  background:linear-gradient(160deg,rgba(16,21,43,.9),rgba(5,7,15,.9));
  padding:clamp(36px,6vw,72px);
  display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;
  position:relative;overflow:hidden;
}
.calc::before{
  content:"";position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 60% 80% at 100% 0%,rgba(139,108,240,.12),transparent 60%);
}
.calc h2{font-size:clamp(1.9rem,3.6vw,2.7rem);margin:.5em 0 .5em}
.reduce{
  font-family:'Cormorant Garamond',serif;text-align:center;user-select:none;
}
.reduce .row{font-size:clamp(1.3rem,3vw,1.8rem);color:var(--ink-dim);letter-spacing:.28em}
.reduce .arrow{color:var(--violet);font-size:1.4rem;margin:.35em 0;opacity:.8}
.reduce .code{
  font-size:clamp(3rem,8vw,4.6rem);color:var(--gold-bright);letter-spacing:.3em;padding-left:.3em;
  text-shadow:0 0 26px rgba(217,180,92,.5),0 0 70px rgba(139,108,240,.35);
  animation:breathe 6s ease-in-out infinite;
}
.reduce .cap{font-family:'Inter',sans-serif;font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-dim);margin-top:1.4em}

/* ---------- 248 ---------- */
.infinity-wrap{display:flex;justify-content:center;margin:44px 0 34px}
.infinity{width:min(86vw,520px);overflow:visible}
.lem-base{fill:none;stroke:rgba(217,180,92,.22);stroke-width:1.2}
.lem-light{
  fill:none;stroke:var(--gold-bright);stroke-width:1.8;stroke-linecap:round;
  stroke-dasharray:70 640;
  filter:drop-shadow(0 0 6px rgba(240,212,137,.9)) drop-shadow(0 0 18px rgba(139,108,240,.6));
  animation:trace 7s linear infinite;
}
@keyframes trace{to{stroke-dashoffset:-710}}
.n248{display:flex;justify-content:center;gap:clamp(28px,8vw,72px);margin-top:8px}
.n248 div{text-align:center}
.n248 .num{font-family:'Cormorant Garamond',serif;font-size:clamp(2.6rem,7vw,4rem);color:var(--gold-bright)}
.n248 .lbl{font-size:.68rem;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-dim)}
.sec-248 h2{font-size:clamp(2rem,4.4vw,3.2rem)}
.sec-248 .lede{margin-top:1.2em}

/* ---------- angel numbers ---------- */
.tiles{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:56px}
.tile{
  border:1px solid var(--hairline);border-radius:18px;padding:34px 20px 30px;
  background:rgba(10,14,30,.55);text-align:center;position:relative;overflow:hidden;
  transition:transform .5s var(--ease),border-color .5s,box-shadow .5s;
}
.tile::before{
  content:"";position:absolute;inset:0;opacity:0;transition:opacity .5s;
  background:radial-gradient(ellipse 90% 60% at 50% 0%,var(--violet-glow),transparent 70%);
}
.tile:hover{transform:translateY(-6px);border-color:rgba(217,180,92,.45);box-shadow:0 18px 50px -18px rgba(139,108,240,.5)}
.tile:hover::before{opacity:1}
.tile .num{
  font-family:'Cormorant Garamond',serif;font-size:2.3rem;color:var(--gold-bright);
  text-shadow:0 0 22px rgba(217,180,92,.4);position:relative;
}
.tile p{font-size:.82rem;color:var(--ink-dim);margin-top:.7em;position:relative}
.sec-angel h2{font-size:clamp(2rem,4vw,2.9rem)}

/* ---------- final CTA ---------- */
.final{
  text-align:center;position:relative;padding:150px 24px 140px;overflow:hidden;
}
.final::before{
  content:"";position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
  width:min(120vw,900px);aspect-ratio:1;border-radius:50%;pointer-events:none;
  background:radial-gradient(circle,rgba(139,108,240,.16),transparent 62%);
}
.final h2{font-size:clamp(2.3rem,5.6vw,3.9rem);max-width:14em;margin:0 auto .4em;position:relative}
.final .lede{margin:0 auto 2.6em;position:relative}
.secondary{
  display:flex;gap:44px;justify-content:center;flex-wrap:wrap;
  margin-top:74px;position:relative;
}
.sec-card{max-width:230px;text-align:center}
.sec-card .serif{font-size:1.25rem;color:var(--ink)}
.sec-card p{font-size:.8rem;color:var(--ink-dim);margin:.45em 0 .9em}

/* ---------- footer ---------- */
footer{
  border-top:1px solid var(--hairline);padding:44px 24px;text-align:center;
  font-size:.72rem;letter-spacing:.14em;color:var(--ink-dim);
}
footer .serif{color:var(--gold);font-size:1rem;letter-spacing:.3em;text-transform:uppercase;display:block;margin-bottom:.8em}

/* ---------- trust ---------- */
.trust{
  margin:2.4em auto 0;max-width:32em;position:relative;z-index:2;
  font-size:.78rem;letter-spacing:.05em;color:var(--ink-dim);line-height:1.8;
}
.trust strong{color:var(--gold);font-weight:500}
.collection-link{display:inline-block;margin-top:48px}

/* ---------- follow / social ---------- */
.social-row{display:flex;gap:20px;justify-content:center;margin-top:44px}
.social-row a{
  width:54px;height:54px;border:1px solid var(--hairline);border-radius:50%;
  display:flex;align-items:center;justify-content:center;color:var(--gold);
  transition:transform .4s var(--ease),border-color .4s,box-shadow .4s;
}
.social-row a:hover{transform:translateY(-4px);border-color:rgba(217,180,92,.55);box-shadow:0 12px 34px -12px rgba(139,108,240,.55)}
.social-row a:focus-visible{outline:2px solid var(--cyan);outline-offset:3px}
.social-row svg{width:20px;height:20px;fill:currentColor}

/* ---------- footer nav ---------- */
footer nav{display:flex;flex-wrap:wrap;gap:12px 28px;justify-content:center;margin:22px auto 28px;max-width:720px}
footer nav a{color:var(--ink-dim);text-decoration:none;font-size:.72rem;letter-spacing:.14em;transition:color .3s}
footer nav a:hover{color:var(--gold)}
footer nav a:focus-visible{outline:2px solid var(--cyan);outline-offset:3px}
footer .social-row{margin:6px 0 26px}
footer .social-row a{width:42px;height:42px}
footer .social-row svg{width:16px;height:16px}
.copyright{opacity:.7}

/* ---------- responsive ---------- */
@media(max-width:860px){
  section{padding:80px 0}
  .about-grid{grid-template-columns:1fr;gap:44px}
  .about-grid .sigil{order:-1;max-width:240px}
  .calc{grid-template-columns:1fr;gap:40px}
  .tiles{grid-template-columns:repeat(2,1fr)}
  .journey .wrap{grid-template-columns:repeat(2,1fr)}
  .stage:nth-child(3)::before{display:none}
  .stage:nth-child(n+3){border-top:1px solid var(--hairline)}
}
@media(max-width:420px){
  .tiles{grid-template-columns:1fr 1fr;gap:12px}
  .tile{padding:26px 12px 22px}
}

/* ---------- reduced motion ---------- */
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation:none!important;transition:none!important}
  .rv{opacity:1;transform:none}
  html{scroll-behavior:auto}
}
</style>
</head>
