---
import { SITE } from '../lib/site';

interface Props {
  size?: 'sm' | 'lg';
}
const { size = 'lg' } = Astro.props;

const links = [
  { key: 'facebook', label: 'Facebook', href: SITE.social.facebook },
  { key: 'instagram', label: 'Instagram', href: SITE.social.instagram },
  { key: 'youtube', label: 'YouTube', href: SITE.social.youtube },
  { key: 'tiktok', label: 'TikTok', href: SITE.social.tiktok },
] as const;
---
<div class:list={['social-row', size === 'sm' && 'sm']}>
  {links.map((l) => (
    <a href={l.href} target="_blank" rel="noopener" aria-label={l.label}>
      {l.key === 'facebook' && (
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 8.5h2.5V5.2c-.43-.06-1.9-.2-3.1-.2-3.07 0-5 1.83-5 5.2v2.6H6.3V16h3.1v8h3.6v-8h3.06l.5-3.2h-3.56v-2.2c0-.93.26-1.6 1.9-1.6z"/></svg>
      )}
      {l.key === 'instagram' && (
        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.5" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="4.6" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="17.4" cy="6.6" r="1.15"/></svg>
      )}
      {l.key === 'youtube' && (
        <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="1.5" y="5" width="21" height="14" rx="4" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M10 8.6v6.8l6-3.4z"/></svg>
      )}
      {l.key === 'tiktok' && (
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 2.5h2.7c.2 1.7 1.2 3.2 3.3 3.6v2.8c-1.3 0-2.5-.4-3.5-1.1v6.3a5.5 5.5 0 1 1-5.5-5.5c.2 0 .4 0 .6.02v2.8a2.6 2.6 0 1 0 1.9 2.5V2.5z"/></svg>
      )}
    </a>
  ))}
</div>
