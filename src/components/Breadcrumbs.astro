---
interface Props {
  crumbs: { name: string; href: string }[];
}
const { crumbs } = Astro.props;
---
<nav class="crumbs" aria-label="Breadcrumb">
  {crumbs.map((c, i) => (
    <>
      {i > 0 && <span aria-hidden="true">›</span>}
      {i < crumbs.length - 1 ? <a href={c.href}>{c.name}</a> : <span aria-current="page">{c.name}</span>}
    </>
  ))}
</nav>
