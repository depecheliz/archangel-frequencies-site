---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Cta from '../../components/Cta.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';
const path = '/frequency/';
const title = 'Frequency: Solfeggio Tones & the Frequency Code™';
const description = 'Frequency explained — solfeggio tones like 528Hz and 432Hz, how sound is used in spiritual practice, and the Frequency Code™ methodology.';
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Frequency', href: path }];
const schema = [articleSchema({ title, description, path }), breadcrumbSchema(crumbs)];
---
<Base title={title} description={description} schema={schema}>
  <div class="article">
    <Breadcrumbs crumbs={crumbs} />
    <header class="hero"><p class="eyebrow">Pillar Guide</p><h1>Frequency</h1>
    <p class="lead">Numbers you see. Frequencies you feel. The same pattern, two senses.</p></header>
    <p>This pillar covers frequency in spiritual practice: the solfeggio tones (528Hz, 432Hz, 963Hz and the rest of the scale), how sound is used in meditation and manifestation work, and our own methodology — the Frequency Code™ and the <a href="/frequency/248/">248 Frequency™</a>. Individual tone guides are being published.</p>
    <ul class="hub-grid">
      <li><a class="hub-card" href="/frequency/248/"><h3>The 248 Frequency™</h3><p>Our signature methodology — what it is and how it is read.</p></a></li>
      <li><a class="hub-card" href="/angel-numbers/"><h3>Angel Numbers</h3><p>The visual form of the same pattern language.</p></a></li>
      <li><a class="hub-card" href="/manifestation/"><h3>Manifestation</h3><p>Putting frequency and state to work.</p></a></li>
    </ul>
    <Cta />
  </div>
</Base>
