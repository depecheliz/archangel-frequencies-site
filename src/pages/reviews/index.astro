---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbSchema } from '../../lib/schema';
const path = '/reviews/';
const title = 'Reviews: Spiritual Products & Readings, Tested Honestly';
const description = 'First-hand reviews of numerology readings, spiritual courses, and apps — what we bought, what we found, and who each product actually fits.';
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Reviews', href: path }];
const reviews = [
  { name: 'Numerologist.com Review', href: '/reviews/numerologist-review/', blurb: 'The biggest name in numerology reports — legit, but is it worth it?' },
];
const schema = [breadcrumbSchema(crumbs)];
---
<Base title={title} description={description} schema={schema}>
  <div class="wrap" style="max-width:900px">
    <Breadcrumbs crumbs={crumbs} />
    <header class="hero"><p class="eyebrow">Reviews</p><h1>Reviews</h1>
    <p class="lead">We buy the product, read the whole thing, and tell you who it fits — including when the answer is "not you." Every page carries a disclosure.</p></header>
    <ul class="hub-grid">{reviews.map((g) => (<li><a class="hub-card" href={g.href}><h3>{g.name}</h3><p>{g.blurb}</p></a></li>))}</ul>
    <p class="muted">In the queue: Moonology, psychic reading networks, and spiritual app reviews.</p>
  </div>
</Base>
