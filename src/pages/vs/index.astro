---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbSchema } from '../../lib/schema';
const path = '/vs/';
const title = 'Comparisons: Readings & Spiritual Tools Head-to-Head';
const description = 'Side-by-side comparisons of numerology readings, spiritual apps, and courses.';
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Comparisons', href: path }];
const schema = [breadcrumbSchema(crumbs)];
---
<Base title={title} description={description} schema={schema} noindex={true}>
  <div class="wrap" style="max-width:900px">
    <Breadcrumbs crumbs={crumbs} />
    <header class="hero"><p class="eyebrow">Comparisons</p><h1>Head-to-Head Comparisons</h1>
    <p class="lead">First comparisons are in production. Meanwhile, the <a href="/reviews/numerologist-review/">Numerologist.com review</a> includes a side-by-side table.</p></header>
  </div>
</Base>
