---
import { SITE, NAV, REVEAL_PATH, EXTERNAL } from '../lib/site';
import { organizationSchema, websiteSchema } from '../lib/schema';
import SocialRow from '../components/SocialRow.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Extra JSON-LD blocks (already-built objects) */
  schema?: object[];
  /** Set true only on the homepage to emit Organization + WebSite schema */
  isHome?: boolean;
  noindex?: boolean;
}

const { title, description, schema = [], isHome = false, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL('/og-image.png', SITE.url).href;
const blocks = [...(isHome ? [organizationSchema(), websiteSchema()] : []), ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {blocks.map((b) => <script type="application/ld+json" set:html={JSON.stringify(b)} />)}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap bar">
        <a class="brand" href="/">Archangel <em>Frequencies</em></a>
        <nav class="nav" aria-label="Primary">
          {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap cols">
        <div>
          <p class="brand" style="padding:0">Archangel <em>Frequencies</em></p>
          <p>{SITE.tagline}</p>
        </div>
        <div>
          <p class="eyebrow">Explore</p>
          <a href="/angel-numbers/">Angel Numbers</a>
          <a href="/angel-numbers/meanings/">All Number Meanings</a>
          <a href="/numerology/">Numerology</a>
          <a href="/archangels/">Archangels</a>
          <a href="/frequency/">Frequency</a>
          <a href="/manifestation/">Manifestation</a>
        </div>
        <div>
          <p class="eyebrow">Tools</p>
          <a href="/angel-numbers/calculator/">Angel Number Calculator</a>
          <a href="/calculators/life-path/">Life Path Calculator</a>
          <a href="/calculators/personal-year/">Personal Year Calculator</a>
          <a href="/calculators/mirror-hour/">Mirror Hour Decoder</a>
        </div>
        <div>
          <p class="eyebrow">Company</p>
          <a href="/about/">About</a>
          <a href="/methodology/">Our Methodology</a>
          <a href="/frequency/code/">The Frequency Code™</a>
          <a href="/best/">Best-Of Guides</a>
          <a href={REVEAL_PATH}>Get Your Frequency Code</a>
        </div>
      </div>
      <div class="wrap" style="margin-top:28px">
        <SocialRow size="sm" />
        <p style="margin-top:18px; font-size:0.78rem; text-align:center">
          Elsewhere: <a href={EXTERNAL.app} target="_blank" rel="noopener">App</a> ·{' '}
          <a href={EXTERNAL.community} target="_blank" rel="noopener">Community</a> ·{' '}
          <a href={EXTERNAL.amazonBooks} target="_blank" rel="noopener">Books</a>
        </p>
        <p style="margin-top:12px; font-size:0.78rem">
          &copy; {new Date().getFullYear()} {SITE.name}. For reflection and entertainment; not a substitute for
          professional advice. Some pages contain affiliate links; see each page's disclosure.{' '}
          <a href="/privacy/">Privacy Policy</a> · <a href="/terms/">Terms of Use</a>
        </p>
      </div>
    </footer>
  </body>
</html>
